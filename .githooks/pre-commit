#!/usr/bin/env bash
# pre-commit hook: run go tests before allowing a commit.
#
# This hook is version-controlled under .githooks/ and activated via
# `git config core.hooksPath .githooks`. To install for this repo:
#
#   git config core.hooksPath .githooks
#
# Tests are scoped to ./internal/... — cmd/ are cgo (gousb) hardware tools and
# are not unit-tested (see AGENTS.md "测试分层"). The test environment mirrors
# what Makefile sets up, so this hook works independently of `make`.

set -euo pipefail

# Resolve toolchain via mise (same approach as Makefile: mise exec does not work
# in non-interactive shells on Windows, but `mise where` does).
GOROOT="$(mise where go 2>/dev/null || true)"
if [ -z "$GOROOT" ]; then
  echo "pre-commit: mise/go not found — skipping tests (install mise + run 'mise install')" >&2
  exit 0
fi
GO="$GOROOT/bin/go"

# Project-local GOPATH (cross-platform — both Windows and macOS use this).
ROOT="$(git rev-parse --show-toplevel)"
export GOPATH="$ROOT/.gopath"
export GOBIN=""

# Windows-only env: go.exe is a Windows binary and needs Windows-style paths
# + the mingw64 toolchain (mirrors Makefile). macOS/Linux use mise's go +
# system clang/gcc + brew/system libusb directly, so no overrides needed.
if [[ "$(uname -s)" == MINGW* ]] || [[ "$(uname -s)" == MSYS* ]]; then
	USER_HOME="${USERPROFILE:-$HOME}"
	# Convert /c/Users/... to C:\Users\... so go.exe (Windows binary) accepts it.
	WIN_HOME="$(echo "$USER_HOME" | sed 's|^/\([a-zA-Z]\)/|\1:\\|; s|/|\\|g')"
	export LocalAppData="${LocalAppData:-${WIN_HOME}\\AppData\\Local}"
	export APPDATA="${APPDATA:-${WIN_HOME}\\AppData\\Roaming}"
	export TMP="${TMP:-${WIN_HOME}\\AppData\\Local\\Temp}"
	export TEMP="${TEMP:-${WIN_HOME}\\AppData\\Local\\Temp}"
	export GOTMPDIR="${GOTMPDIR:-${WIN_HOME}\\AppData\\Local\\Temp}"
	export CC="C:\\msys64\\mingw64\\bin\\gcc.exe"
	export PKG_CONFIG_PATH="C:\\msys64\\mingw64\\lib\\pkgconfig"
	export PATH="$GOPATH/bin:/c/msys64/mingw64/bin:$PATH"

fi
ROOT="$(git rev-parse --show-toplevel)"
PII_FILE="$ROOT/.piipatterns"

# PII patterns are stored in .piipatterns (gitignored, NOT in version control).
# See .piipatterns.example for format and setup instructions.
# If .piipatterns is missing, PII check is skipped with a warning.
if [ ! -f "$PII_FILE" ]; then
  echo "pre-commit: ⚠️  .piipatterns not found — PII check skipped." >&2
  echo "  Copy .piipatterns.example → .piipatterns and fill in real patterns." >&2
else
  echo "pre-commit: checking staged content for PII..."
  # Each line in .piipatterns is a regex pattern (grep -E syntax).
  # Empty lines and lines starting with # are ignored.
  PII_REGEX=$(grep -v '^#' "$PII_FILE" | grep -v '^$' | paste -sd'|' -)

  if [ -n "$PII_REGEX" ]; then
    # --no-ext-diff forces git's built-in patch format (+/- lines); external
    # diff drivers (delta/difftastic) emit non-standard output without "+"
    # prefixes that silently defeats this grep (root cause of past PII leaks).
    PII_HITS=$(git diff --cached --no-ext-diff -U0 --diff-filter=ACM -- \
      '*.go' '*.md' '*.txt' '*.json' '*.yaml' '*.yml' '*.bat' '*.sh' '*.inf' \
      | grep -E '^\+' | grep -iE "$PII_REGEX" 2>/dev/null || true)

    if [ -n "$PII_HITS" ]; then
      echo "" >&2
      echo "pre-commit: ❌ PII DETECTED in staged changes — commit aborted." >&2
      echo "" >&2
      echo "$PII_HITS" >&2
      echo "" >&2
      echo "Redact these values before committing." >&2
      echo "Bypass with 'git commit --no-verify' (NOT recommended for PII)." >&2
      exit 1
    fi
  fi

  echo "pre-commit: PII check passed ✓"
fi

echo "pre-commit: running go test ./internal/... (race detector on)"
# -race is mandatory for transport/concurrency code per AGENTS.md testing policy.
if ! "$GO" test -race ./internal/...; then
  echo "" >&2
  echo "pre-commit: TESTS FAILED — commit aborted." >&2
  echo "Run 'make test-race' to debug, or bypass with 'git commit --no-verify' (not recommended)." >&2
  exit 1
fi

echo "pre-commit: tests passed ✓"
exit 0
