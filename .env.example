# Hardware test configuration — copy to .env and fill in your values.
# .env is gitignored; these values are injected at runtime.

# SMS test recipient (required for Send hardware test)
DJI_TEST_SMS_RECIPIENT="+8613800000000"

# APN for QMI dialup (default: 3gnet)
DJI_TEST_APN=3gnet

# SMS service center (optional, auto-detected from SIM)
# DJI_TEST_SMSC="+8613010000000"
